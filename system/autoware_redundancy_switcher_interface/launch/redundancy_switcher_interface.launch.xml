<launch>
  <arg name="is_main_ecu" default="true"/>
  <arg name="base_config" default="$(find-pkg-share autoware_redundancy_switcher_interface)/config/default.param.yaml"/>
  <arg name="plugin_config" default="$(find-pkg-share autoware_redundancy_switcher_interface_plugins)/config/default.param.yaml"/>

  <!-- Input topics -->
  <arg name="input_velocity" default="/vehicle/status/velocity_status"/>
  <arg name="input_control_mode" default="/vehicle/status/control_mode"/>
  <arg name="input_command_mode_request" default="/system/command_mode/request"/>
  <arg name="input_command_mode_availability" default="/system/command_mode/availability"/>

  <!-- Output topics -->
  <arg name="output_active_control_unit" default="/system/redundancy/active_control_unit"/>

  <!-- Services -->
  <arg name="service_set_initializing" default="/system/redundancy_switcher_interface/set_initializing"/>
  <arg name="service_reset" default="/system/redundancy_switcher/reset"/>

  <!-- Node name prefix -->
  <let name="node_name_prefix" value="main_ecu" if="$(var is_main_ecu)"/>
  <let name="node_name_prefix" value="sub_ecu" unless="$(var is_main_ecu)"/>

  <node pkg="autoware_redundancy_switcher_interface" exec="redundancy_switcher_interface_node" name="$(var node_name_prefix)_redundancy_switcher_interface" output="screen">
    <param name="is_main_ecu" value="$(var is_main_ecu)"/>
    <param from="$(var base_config)"/>
    <param from="$(var plugin_config)"/>

    <remap from="~/input/velocity" to="$(var input_velocity)"/>
    <remap from="~/input/control_mode" to="$(var input_control_mode)"/>
    <remap from="~/input/command_mode_request" to="$(var input_command_mode_request)"/>
    <remap from="~/input/command_mode_availability" to="$(var input_command_mode_availability)"/>

    <remap from="~/output/active_control_unit" to="$(var output_active_control_unit)"/>

    <remap from="~/set_initializing" to="$(var service_set_initializing)"/>
    <remap from="~/service/reset" to="$(var service_reset)"/>
  </node>
</launch>

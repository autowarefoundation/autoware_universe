{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Parameters for autoware_redundancy_switcher_interface",
  "type": "object",
  "definitions": {
    "diag": {
      "type": "object",
      "properties": {
        "transitional_timeout_milli": {
          "type": "number",
          "description": "Elapsed time [ms] after which a transitional switcher state (startup or state change in progress) is reported as DiagStatus::ERROR.",
          "default": 10000.0,
          "exclusiveMinimum": 0
        }
      },
      "required": ["transitional_timeout_milli"],
      "additionalProperties": false
    },
    "base_params": {
      "type": "object",
      "properties": {
        "use_driving_mode": {
          "type": "boolean",
          "description": "Set to true to receive DrivingMode commands from the subsystem; false to receive CommandMode commands.",
          "default": false
        },
        "availability_timeout_milli": {
          "type": "number",
          "description": "Elapsed time [ms] without CommandModeAvailability from the peer ECU before the peer is considered unavailable. Only used when use_driving_mode=false.",
          "exclusiveMinimum": 0
        },
        "diag": {
          "$ref": "#/definitions/diag"
        }
      },
      "required": ["use_driving_mode", "diag"],
      "additionalProperties": true
    }
  },
  "properties": {
    "/**": {
      "type": "object",
      "properties": {
        "ros__parameters": {
          "$ref": "#/definitions/base_params"
        }
      },
      "required": ["ros__parameters"],
      "additionalProperties": false
    }
  },
  "required": ["/**"],
  "additionalProperties": false
}

{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Parameters for ptv3",
  "type": "object",
  "definitions": {
    "ptv3": {
      "type": "object",
      "properties": {
        "class_names": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Predicted classes' names.",
          "default": ["CAR", "TRUCK", "BUS", "BICYCLE", "PEDESTRIAN"],
          "uniqueItems": true
        },
        "palette": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 0,
            "maximum": 255
          },
          "description": "Flat RGB palette for visualization output. Must contain 3 values per class in class_names."
        },
        "voxels_num": {
          "type": "array",
          "items": {
            "type": "integer"
          },
          "description": "Voxel ranges used during inference [min, opt, max].",
          "default": [5000, 30000, 60000]
        },
        "point_cloud_range": {
          "type": "array",
          "items": {
            "type": "number"
          },
          "description": "Range in meters of the pointcloud in meters [min_x, min_y, min_z, max_x, max_y, max_z].",
          "default": [-76.8, -76.8, -3.0, 76.8, 76.8, 5.0],
          "minItems": 6,
          "maxItems": 6
        },
        "voxel_size": {
          "type": "array",
          "items": {
            "type": "number"
          },
          "description": "Voxels size [x, y, z] in meters.",
          "default": [0.3, 0.3, 8.0],
          "minItems": 3,
          "maxItems": 3
        },
        "serialization_orders": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["z", "z-trans"]
          },
          "description": "Space-filling curve serialization orders used by the exported model.",
          "default": ["z", "z-trans"],
          "minItems": 2,
          "maxItems": 2
        },
        "pooling_strides": {
          "type": "array",
          "items": {
            "type": "integer",
            "enum": [2]
          },
          "description": "SerializedPooling strides for each encoder downsampling stage.",
          "default": [2, 2, 2, 2]
        }
      },
      "required": [
        "class_names",
        "palette",
        "voxels_num",
        "point_cloud_range",
        "voxel_size",
        "serialization_orders",
        "pooling_strides"
      ],
      "additionalProperties": false
    }
  },
  "properties": {
    "/**": {
      "type": "object",
      "properties": {
        "ros__parameters": {
          "$ref": "#/definitions/ptv3"
        }
      },
      "required": ["ros__parameters"],
      "additionalProperties": false
    }
  },
  "required": ["/**"],
  "additionalProperties": false
}

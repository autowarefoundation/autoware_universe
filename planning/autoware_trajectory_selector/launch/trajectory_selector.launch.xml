<?xml version="1.0" encoding="UTF-8"?>
<launch>
  <arg name="trajectory_selector_param_path" default="$(find-pkg-share autoware_trajectory_selector)/config/selector.param.yaml"/>
  <arg name="trajectory_concatenator_param_path" default="$(find-pkg-share autoware_trajectory_concatenator)/config/concatenator.param.yaml"/>
  <arg name="trajectory_validator_param_path" default="$(find-pkg-share autoware_trajectory_validator)/config/trajectory_validator.param.yaml"/>
  <arg name="input_generative_trajectories" default="~/input/trajectories_generative"/>
  <arg name="input_backup_trajectories" default="~/input/trajectories_backup"/>
  <arg name="output_trajectories" default="~/output/trajectories"/>
  <arg name="input_vector_map" default="~/input/vector_map"/>
  <arg name="input_odometry" default="~/input/odometry"/>
  <arg name="input_objects" default="~/input/objects"/>
  <arg name="input_diffusion_objects" default="/planning/trajectory_generator/neural_network_based_planner/diffusion_planner_node/output/predicted_objects"/>
  <arg name="input_acceleration" default="~/input/acceleration"/>
  <arg name="input_traffic_signals" default="~/input/traffic_signals"/>
  <arg name="input_route" default="/planning/mission_planning/route"/>

  <arg name="enable_pseudo_emergency_stop" default="false"/>

  <node pkg="autoware_trajectory_selector" exec="autoware_trajectory_selector_node" name="trajectory_selector_node" output="screen">
    <param from="$(var trajectory_selector_param_path)" allow_substs="true"/>
    <param from="$(var trajectory_concatenator_param_path)" allow_substs="true"/>
    <param from="$(var trajectory_validator_param_path)" allow_substs="true"/>
    <param name="pseudo_emergency_stop.enable" value="$(var enable_pseudo_emergency_stop)"/>
    <remap from="~/input/trajectories_generative" to="$(var input_generative_trajectories)"/>
    <remap from="~/input/trajectories_backup" to="$(var input_backup_trajectories)"/>
    <remap from="~/output/trajectories" to="$(var output_trajectories)"/>
    <remap from="~/input/lanelet2_map" to="$(var input_vector_map)"/>
    <remap from="~/input/odometry" to="$(var input_odometry)"/>
    <remap from="~/input/objects" to="$(var input_objects)"/>
    <remap from="~/input/diffusion/objects" to="$(var input_diffusion_objects)"/>
    <remap from="~/input/acceleration" to="$(var input_acceleration)"/>
    <remap from="~/input/traffic_signals" to="$(var input_traffic_signals)"/>
    <remap from="~/input/route" to="$(var input_route)"/>
  </node>
</launch>

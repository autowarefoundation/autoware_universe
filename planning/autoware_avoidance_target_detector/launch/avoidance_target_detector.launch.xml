<?xml version="1.0" encoding="UTF-8"?>
<launch>
  <arg name="input_objects" default="/planning/trajectory_generator/neural_network_based_planner/diffusion_planner_node/output/predicted_objects"/>
  <arg name="input_tracked_objects" default="/perception/object_recognition/tracking/objects"/>
  <arg name="input_trajectory" default="/planning/trajectory_generator/neural_network_based_planner/diffusion_planner_node/output/trajectory"/>
  <arg name="input_route" default="/planning/route"/>
  <arg name="input_lanelet_map_bin" default="/map/vector_map"/>
  <arg name="output_avoidance_targets" default="/planning/avoidance_target_detector/output/avoidance_targets"/>
  <arg name="output_driving_along_vehicles" default="/planning/avoidance_target_detector/output/driving_along_vehicles"/>
  <arg name="output_tracked_avoidance_targets" default="/planning/avoidance_target_detector/output/tracked_avoidance_targets"/>
  <arg name="output_tracked_driving_along_vehicles" default="/planning/avoidance_target_detector/output/tracked_driving_along_vehicles"/>
  <arg name="debug_avoidance_targets" default="/planning/avoidance_target_detector/debug/avoidance_targets"/>
  <arg name="output_drivable_area" default="/planning/avoidance_target_detector/output/drivable_area"/>
  <arg name="debug_near_segment_polygon" default="/planning/avoidance_target_detector/debug/near_segment_polygon"/>
  <arg name="vehicle_info_param_path" default="$(find-pkg-share j6_gen2_description)/config/vehicle_info.param.yaml"/>

  <node pkg="autoware_avoidance_target_detector" exec="autoware_avoidance_target_detector_node" name="avoidance_target_detector" output="screen">
    <param from="$(var vehicle_info_param_path)"/>
    <remap from="~/input/objects" to="$(var input_objects)"/>
    <remap from="~/input/tracked_objects" to="$(var input_tracked_objects)"/>
    <remap from="~/input/trajectory" to="$(var input_trajectory)"/>
    <remap from="~/input/route" to="$(var input_route)"/>
    <remap from="~/input/lanelet_map_bin" to="$(var input_lanelet_map_bin)"/>
    <remap from="~/output/avoidance_targets" to="$(var output_avoidance_targets)"/>
    <remap from="~/output/driving_along_vehicles" to="$(var output_driving_along_vehicles)"/>
    <remap from="~/output/tracked_avoidance_targets" to="$(var output_tracked_avoidance_targets)"/>
    <remap from="~/output/tracked_driving_along_vehicles" to="$(var output_tracked_driving_along_vehicles)"/>
    <remap from="~/debug/avoidance_targets" to="$(var debug_avoidance_targets)"/>
    <remap from="~/output/drivable_area" to="$(var output_drivable_area)"/>
    <remap from="~/debug/near_segment_polygon" to="$(var debug_near_segment_polygon)"/>
    <param name="longitudinal_distance_filter.tolerance_m" value="2.0"/>
    <param name="lateral_distance_filter.tolerance_m" value="1.0"/>
  </node>
</launch>

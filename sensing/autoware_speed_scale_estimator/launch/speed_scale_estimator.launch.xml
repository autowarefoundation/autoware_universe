<launch>
  <arg name="param_path" default="$(find-pkg-share autoware_speed_scale_estimator)/config/speed_scale_estimator.yaml"/>
  <arg name="use_sim_time" default="false"/>
  <arg name="input_pose_name" default="/localization/pose_estimator/pose"/>
  <arg name="input_velocity_report" default="/vehicle/status/velocity_status"/>
  <arg name="input_imu" default="/sensing/imu/imu_data"/>
  <arg name="output_scale_factor" default="/sensing/speed_scale_estimator/scale_factor"/>
  <arg name="output_debug_info" default="/sensing/speed_scale_estimator/debug_info"/>

  <node pkg="autoware_speed_scale_estimator" exec="speed_scale_estimator_node" name="speed_scale_estimator" output="screen">
    <param name="use_sim_time" value="$(var use_sim_time)"/>
    <remap from="~/input/pose" to="$(var input_pose_name)"/>
    <remap from="~/input/velocity_report" to="$(var input_velocity_report)"/>
    <remap from="~/input/imu" to="$(var input_imu)"/>
    <remap from="~/output/scale_factor" to="$(var output_scale_factor)"/>
    <remap from="~/output/debug_info" to="$(var output_debug_info)"/>

    <param from="$(var param_path)"/>
  </node>
</launch>

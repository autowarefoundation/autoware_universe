<?xml version="1.0" encoding="UTF-8"?>
<launch>
  <arg name="oneplanner_param_path" default="$(find-pkg-share autoware_tensorrt_oneplanner)/config/oneplanner.param.yaml"/>
  <arg name="data_path" default="$(env HOME)/autoware_data/ml_models" description="packages data and artifacts directory path"/>
  <arg name="model_path" default="$(var data_path)/oneplanner" description="oneplanner artifacts (onnx models, args json) directory"/>
  <arg name="vehicle_info_param_path" default="$(find-pkg-share autoware_vehicle_info_utils)/config/vehicle_info.param.yaml"/>

  <arg name="input_pointcloud" default="/sensing/lidar/concatenated/pointcloud"/>
  <arg name="input_odometry" default="~/input/odometry"/>
  <arg name="input_acceleration" default="~/input/acceleration"/>
  <arg name="input_route" default="~/input/route"/>
  <arg name="input_traffic_signals" default="~/input/traffic_signals"/>
  <arg name="input_vector_map" default="~/input/vector_map"/>
  <arg name="input_turn_indicators" default="~/input/turn_indicators"/>
  <arg name="output_trajectory" default="~/output/trajectory"/>
  <arg name="output_trajectories" default="~/output/trajectories"/>
  <arg name="output_turn_indicators" default="~/output/turn_indicators"/>
  <arg name="build_only" default="false" description="shutdown node after TensorRT engine files are built"/>

  <node pkg="autoware_tensorrt_oneplanner" exec="autoware_tensorrt_oneplanner_node" name="tensorrt_oneplanner" output="both">
    <param from="$(var oneplanner_param_path)" allow_substs="true"/>
    <param from="$(var vehicle_info_param_path)" allow_substs="true"/>
    <remap from="~/input/pointcloud" to="$(var input_pointcloud)"/>
    <remap from="~/input/pointcloud/cuda" to="$(var input_pointcloud)/cuda"/>
    <remap from="~/input/odometry" to="$(var input_odometry)"/>
    <remap from="~/input/acceleration" to="$(var input_acceleration)"/>
    <remap from="~/input/route" to="$(var input_route)"/>
    <remap from="~/input/traffic_signals" to="$(var input_traffic_signals)"/>
    <remap from="~/input/vector_map" to="$(var input_vector_map)"/>
    <remap from="~/input/turn_indicators" to="$(var input_turn_indicators)"/>
    <remap from="~/output/trajectory" to="$(var output_trajectory)"/>
    <remap from="~/output/trajectories" to="$(var output_trajectories)"/>
    <remap from="~/output/turn_indicators" to="$(var output_turn_indicators)"/>
    <param name="build_only" value="$(var build_only)"/>
  </node>
</launch>

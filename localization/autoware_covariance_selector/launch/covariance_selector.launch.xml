<?xml version="1.0"?>
<launch>
  <arg name="input/lanelet2_map" default="/map/vector_map"/>
  <arg name="input/pose_with_covariance" default="/localization/pose_estimator/pose_estimator/pose_with_covariance"/>
  <arg name="output/pose_with_covariance" default="/localization/pose_estimator/pose_with_covariance"/>
  <arg name="param_file" default="$(find-pkg-share autoware_covariance_selector)/config/covariance_selector.param.yaml"/>

  <node pkg="autoware_covariance_selector" exec="autoware_covariance_selector_node" output="both">
    <remap from="~/input/lanelet2_map" to="$(var input/lanelet2_map)"/>
    <remap from="~/input/pose_with_covariance" to="$(var input/pose_with_covariance)"/>
    <remap from="~/output/pose_with_covariance" to="$(var output/pose_with_covariance)"/>
    <param from="$(var param_file)"/>
  </node>
</launch>

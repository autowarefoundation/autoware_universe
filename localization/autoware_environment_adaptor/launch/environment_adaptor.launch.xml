<?xml version="1.0"?>
<launch>
  <arg name="input/lanelet2_map" default="/map/vector_map"/>
  <arg name="input/pose_with_covariance" default="/localization/pose_estimator/ndt_scan_matcher/pose_with_covariance"/>
  <arg name="output/pose_with_covariance" default="/localization/pose_estimator/pose_with_covariance"/>
  <arg name="input/twist_with_covariance" default="/sensing/vehicle_velocity_converter/twist_with_covariance"/>
  <arg name="output/twist_with_covariance" default="/localization/twist_estimator/twist_with_covariance_scaled"/>
  <arg name="param_file" default="$(find-pkg-share autoware_environment_adaptor)/config/environment_adaptor.param.yaml"/>

  <node pkg="autoware_environment_adaptor" exec="autoware_environment_adaptor_node" output="both">
    <remap from="~/input/lanelet2_map" to="$(var input/lanelet2_map)"/>
    <remap from="~/input/pose_with_covariance" to="$(var input/pose_with_covariance)"/>
    <remap from="~/output/pose_with_covariance" to="$(var output/pose_with_covariance)"/>
    <remap from="~/input/twist_with_covariance" to="$(var input/twist_with_covariance)"/>
    <remap from="~/output/twist_with_covariance" to="$(var output/twist_with_covariance)"/>
    <param from="$(var param_file)"/>
  </node>
</launch>
